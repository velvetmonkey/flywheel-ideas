{
  "name": "@velvetmonkey/flywheel-ideas-core",
  "version": "0.1.0-alpha.1",
  "description": "Core domain logic for flywheel-ideas — lifecycle, assumptions, council dispatcher, outcome propagation. Not intended for direct use; consumed by @velvetmonkey/flywheel-ideas (MCP server).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepack": "cp ../../LICENSE ./LICENSE",
    "postpack": "rm -f LICENSE"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velvetmonkey/flywheel-ideas.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/velvetmonkey/flywheel-ideas#readme",
  "bugs": {
    "url": "https://github.com/velvetmonkey/flywheel-ideas/issues"
  },
  "author": "velvetmonkey",
  "keywords": [
    "flywheel-ideas",
    "decision-ledger",
    "assumptions",
    "council",
    "internal"
  ],
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
